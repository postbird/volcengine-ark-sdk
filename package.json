{
  "name": "volcengine-ark-sdk",
  "version": "1.0.0",
  "type": "module",
  "description": "火山引擎 | 火山方舟 TypeScript SDK",
  "keywords": [
    "volcengine",
    "ark",
    "sdk"
  ],
  "license": "MIT",
  "author": "Alen Lee",
  "repository": {
    "type": "git",
    "url": "https://github.com/ptbird/volcengine-ark-sdk"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "check": "biome check --write",
    "dev": "rslib build --watch",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@rslib/core": "^0.19.6",
    "@types/node": "^24.10.13",
    "typescript": "^5.9.3"
  },
  "private": false
}
